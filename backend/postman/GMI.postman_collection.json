{
  "info": {
    "name": "GMI API",
    "description": "Colección base para Gestión Médica Integral",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login Paciente",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"juan.perez@gmi.local\",\n  \"password\": \"Paciente123*\"\n}"
        }
      }
    },
    {
      "name": "Médicos - Listar",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/medicos", "host": ["{{baseUrl}}"], "path": ["api", "medicos"] }
      }
    },
    {
      "name": "Turnos - Crear",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/turnos", "host": ["{{baseUrl}}"], "path": ["api", "turnos"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"medicoId\": \"{{medicoId}}\",\n  \"inicio\": \"2026-03-20T13:00:00.000Z\",\n  \"modalidad\": \"online\",\n  \"motivo\": \"Consulta general\",\n  \"timezone\": \"America/Argentina/Buenos_Aires\"\n}"
        }
      }
    },
    {
      "name": "Historial - Mi historial",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/historial/mi", "host": ["{{baseUrl}}"], "path": ["api", "historial", "mi"] }
      }
    },
    {
      "name": "Admin - Auditoría",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/admin/auditoria", "host": ["{{baseUrl}}"], "path": ["api", "admin", "auditoria"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "accessToken", "value": "" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "medicoId", "value": "" }
  ]
}