PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://gmi:gmi123@postgres:5432/gmi?schema=public
REDIS_URL=redis://redis:6379

# Generate your own RSA keys for production.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_YOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"

JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7
CORS_ALLOWLIST=http://localhost:5173,http://localhost:8080
BCRYPT_ROUNDS=12

# Must be exactly 32 chars for AES-256-GCM.
APP_ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_SECRET_KEY

# Development-only fallback. Replace in production.
JWT_SECRET=replace-me-in-production
